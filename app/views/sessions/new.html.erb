<% content_for :title, "Sign In | Reimbursement Portal" %>

<main class="signin-page">
  <section class="signin-panel">
    <div class="signin-card">
      <h2>Sign In</h2>
      <% if @error_message.present? %>
        <div class="form-error"><%= @error_message %></div>
      <% end %>
      <%= form_with url: session_path, class: "signin-form" do |form| %>
        <div class="field">
          <%= form.label :email %>
          <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email", placeholder: "Enter email" %>
        </div>

        <div class="field">
          <%= form.label :password %>
          <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter password" %>
        </div>

        <%= form.submit "Sign in", class: "primary-button" %>
      <% end %>
    </div>
  </section>
</main>
